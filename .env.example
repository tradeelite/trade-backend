# Database — Cloud SQL (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tradeelite

# Anthropic — Claude Vision OCR
ANTHROPIC_API_KEY=sk-ant-...

# Twelve Data (optional — only needed if switching provider)
TWELVE_DATA_API_KEY=...

# GCP — for agent query proxy
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
TRADEVIEW_AGENT_RESOURCE_ID=projects/PROJECT_ID/locations/us-central1/reasoningEngines/AGENT_ID

# App
CORS_ORIGINS=http://localhost:3000
