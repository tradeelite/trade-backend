# Rename this file to ".env" and fill in your values.

# Anthropic — required only for OCR screenshot feature
ANTHROPIC_API_KEY=sk-ant-...

# Twelve Data (optional — only if using Twelve Data provider)
TWELVE_DATA_API_KEY=...

# GCP — Firestore uses Application Default Credentials automatically on Cloud Run
# Locally: run `gcloud auth application-default login`
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
TRADEVIEW_AGENT_RESOURCE_ID=

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000
